{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Copicu",
  "version": "0.1.0",
  "identifier": "dev.jpsala.copicu",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Copicu",
        "url": "index.html",
        "width": 820,
        "height": 620,
        "minWidth": 360,
        "minHeight": 320,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "shadow": false,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "target/release/WebView2Loader.dll": "WebView2Loader.dll"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  }
}
