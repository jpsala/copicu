# Copicu AI provider
# Copy this file to .env, then choose one provider block below.
# .env is ignored by git. Do not commit real API keys.

# Active values read by Copicu.
# COPICU_AI_ENDPOINT and COPICU_AI_MODEL override Settings when present.
COPICU_AI_ENDPOINT=https://openrouter.ai/api/v1
COPICU_AI_MODEL=openai/gpt-4.1-mini
COPICU_AI_API_KEY=your_key_here

# OpenRouter
# COPICU_AI_ENDPOINT=https://openrouter.ai/api/v1
# COPICU_AI_MODEL=openai/gpt-4.1-mini
# COPICU_AI_API_KEY=replace_with_openrouter_key

# OpenAI
# COPICU_AI_ENDPOINT=https://api.openai.com/v1
# COPICU_AI_MODEL=gpt-4.1-mini
# COPICU_AI_API_KEY=replace_with_openai_key

# Groq
# COPICU_AI_ENDPOINT=https://api.groq.com/openai/v1
# COPICU_AI_MODEL=openai/gpt-oss-120b
# COPICU_AI_API_KEY=replace_with_groq_key
